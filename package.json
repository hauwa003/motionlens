{
  "name": "motionlens",
  "version": "0.1.0",
  "private": true,
  "description": "Reverse-engineer website animations into AI-ready implementation instructions. See it. Decode it. Recreate it.",
  "workspaces": [
    "extension",
    "web",
    "packages/*"
  ],
  "scripts": {
    "dev:ext": "turbo run dev --filter=motionlens-extension",
    "dev:web": "turbo run dev --filter=motionlens-web",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "packageManager": "npm@10.9.7"
}
